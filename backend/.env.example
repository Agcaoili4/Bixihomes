# Server
NODE_ENV=development
PORT=5050

# CORS — allowed frontend origins (comma-separated for multiple)
CORS_ORIGIN=http://localhost:5173

# JWT — use a cryptographically random string, minimum 32 characters
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-random-string-at-least-32-chars
JWT_EXPIRES_IN=1h

# Admin credentials
# Generate hash with: node -e "import('bcryptjs').then(b => b.hash('your-password', 12).then(console.log))"
ADMIN_EMAIL=admin@bixihomes.com
ADMIN_PASSWORD_HASH=$2a$12$your-bcrypt-hash-here

# SMTP (Nodemailer)
# For Gmail: enable 2FA, then create an App Password at myaccount.google.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password

# Contact form — where submissions are emailed to
CONTACT_EMAIL_TO=info@bixihomes.com
